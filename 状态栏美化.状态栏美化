            }
        } else if (typeof getWorldbookEntry === 'function') {
            try {
                existingEntry = await getWorldbookEntry(targetWorldbook, entryName);
                console.log('✅ 使用 getWorldbookEntry 读取成功');
            } catch (e) {
                console.warn('⚠️ getWorldbookEntry 调用失败:', e.message);
            }
        } else if (typeof findWorldbookEntries === 'function') {
            try {
                const foundEntries = await findWorldbookEntries(targetWorldbook, entry => entry.name === entryName);
                existingEntry = foundEntries[0];
                console.log('✅ 使用 findWorldbookEntries 读取成功');
            } catch (e) {
                console.warn('⚠️ findWorldbookEntries 调用失败:', e.message);
            }
        }
        
        // 解析现有内容
        if (existingEntry && existingEntry.content) {
