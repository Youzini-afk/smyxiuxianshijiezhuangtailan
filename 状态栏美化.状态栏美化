// ========== 世界书条目创建/更新功能 ==========
async function createOrUpdateWorldbookEntry(worldbooks, entryName, entryConfig) {
    try {
        // 检查必要的API是否可用
        if (typeof createWorldbookEntries !== 'function' || typeof deleteWorldbookEntries !== 'function') {
            console.error('❌ 世界书API不可用');
            return;
        }

        // 确定要操作的世界书名称
        const targetWorldbook = worldbooks.primary || worldbooks.additional[0];
        if (!targetWorldbook) {
            console.error('❌ 没有找到可用的世界书');
            return;
        }

        console.log(`📚 目标世界书: ${targetWorldbook}`);

        // 先删除同名的现有条目（如果存在）
        try {
            const deleteResult = await deleteWorldbookEntries(
                targetWorldbook,
                entry => entry.name === entryName,
                { render: 'debounced' }
            );
            
            if (deleteResult.deleted_entries.length > 0) {
                console.log(`🗑️ 删除了 ${deleteResult.deleted_entries.length} 个同名条目`);
            }
        } catch (deleteError) {
            console.log('ℹ️ 没有找到同名条目，将创建新条目');
        }

        // 创建新条目
        const createResult = await createWorldbookEntries(
            targetWorldbook,
            [entryConfig],
            { render: 'debounced' }
        );

        if (createResult.new_entries.length > 0) {
            console.log(`✅ 成功创建世界书条目: ${entryName}`);
