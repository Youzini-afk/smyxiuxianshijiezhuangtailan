function safeGetArray(data, defaultValue = []) {
    try {
        if (Array.isArray(data)) {
            return data.filter(item => item !== '$__META_EXTENSIBLE__$');
        } else if (data && typeof data === 'string') {
            return [data];
        } else if (data === null || data === undefined) {
            return defaultValue;
        } else {
            console.warn('⚠️ 数据不是数组，尝试转换:', data);
            return defaultValue;
        }
    } catch (e) {
        console.warn('⚠️ 处理数组数据时出错:', e);
        return defaultValue;
    }
}

// ========== 卡片状态管理 ==========
function saveCardStates() {
    try {
        const states = {};
        $('.card-container-wrapper').each(function() {
            const $wrapper = $(this);
            const cardId = $wrapper.attr('id');
            const charKey = $wrapper.data('char');
            
            if (cardId && charKey) {
                states[charKey] = {
                    collapsed: $wrapper.hasClass('collapsed'),
                    flipped: $wrapper.find('.character-card-3d').hasClass('flipped')
                };
            }
        });
        
        localStorage.setItem('character-card-states', JSON.stringify(states));
        console.log('💾 已保存卡片状态:', states);
        return states;
    } catch (e) {
        console.warn('⚠️ 保存卡片状态失败:', e);
        return {};
    }
}

function loadCardStates() {
    try {
        const saved = localStorage.getItem('character-card-states');
        if (saved) {
            const states = JSON.parse(saved);
            console.log('📂 加载卡片状态:', states);
            return states;
        }
    } catch (e) {
        console.warn('⚠️ 加载卡片状态失败:', e);
    }
    return {};
}

function restoreCardStates(states) {
    try {
        Object.keys(states).forEach(charKey => {
            const state = states[charKey];
            const $wrapper = $(`.card-container-wrapper[data-char="${charKey}"]`);
            
            if ($wrapper.length > 0) {
                // 恢复收起状态
                if (state.collapsed) {
                    $wrapper.addClass('collapsed');
                    const $collapseBtn = $wrapper.find('.card-collapse-btn');
                    $collapseBtn.html(ICONS.pinFilled);
                    $collapseBtn.attr('title', '展开');
                }
                
                // 恢复翻转状态
                if (state.flipped) {
                    $wrapper.find('.character-card-3d').addClass('flipped');
                }
                
                console.log(`✅ 恢复 ${charKey} 的状态:`, state);
            }
        });
    } catch (e) {
        console.warn('⚠️ 恢复卡片状态失败:', e);
    }
}

function isCharacterData(obj) {
    if (!obj || typeof obj !== 'object') {
        return false;
    }
    
    const coreFields = ['心跳', '基础信息', '服装', '身体特征', '性经验'];
    let matchCount = 0;
    
    for (const field of coreFields) {
        if (obj[field] !== undefined) {
            matchCount++;
        }
    }
    
    return matchCount >= 3;
}

