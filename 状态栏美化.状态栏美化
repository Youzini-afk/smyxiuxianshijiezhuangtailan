// ==================== 拖拽功能 ====================
let dragData = null;
let dragHandlersAttached = false;

function initializeDragFeature() {
    const $container = window.top ? $(window.top.document).find('#character-status') : $('#character-status');
    const container = $container[0];
    
    if (!container) {
        console.error('❌ 容器不存在');
        console.error('jQuery查询结果:', $container.length);
        return;
    }
    
    if (dragHandlersAttached) {
        return;
    }
    
    try {
        const saved = localStorage.getItem('character-status-position');
        if (saved) {
            const pos = JSON.parse(saved);
            container.style.left = pos.left + 'px';
            container.style.top = pos.top + 'px';
        }
    } catch (e) {
        console.warn('⚠️ 恢复拖拽位置失败');
    }
    
    function handleDragStart(clientX, clientY, target) {
        if (dragData) {
            return false;
        }
        
        const $target = $(target);
        
        if ($target.is('button, input, textarea, select, a') || 
            $target.closest('button, input, textarea, select, a').length > 0) {
            return false;
        }
        
        const hasCollapsed = $('.card-container-wrapper.collapsed').length > 0;
        
        if (!hasCollapsed) {
            if ($target.hasClass('card-content-inner') ||
                $target.closest('.card-content-inner').length > 0 ||
                $target.hasClass('character-card-3d') ||
                $target.closest('.character-card-3d').length > 0) {
                return false;
            }
        }
        
        const targetWindow = window.top && window.top.document === container.ownerDocument ? window.top : window;
        const computedStyle = targetWindow.getComputedStyle(container);
        const currentLeft = parseInt(computedStyle.left) || 0;
        const currentTop = parseInt(computedStyle.top) || 0;
        
        dragData = {
            startX: clientX,
            startY: clientY,
            initialLeft: currentLeft,
            initialTop: currentTop
        };
        
        moveCounter = 0;
        
        container.classList.add('dragging');
        return true;
    }
    
    $container.on('mousedown.drag', function(e) {
        if (handleDragStart(e.clientX, e.clientY, e.target)) {
            e.preventDefault();
            e.stopPropagation();
        }
    });
    
    $container.on('touchstart.drag', function(e) {
        const touch = e.originalEvent.touches[0];
        if (handleDragStart(touch.clientX, touch.clientY, e.target)) {
            e.preventDefault();
            e.stopPropagation();
        }
    });
    
    let moveCounter = 0;
    
    function handleDragMove(clientX, clientY) {
        if (!dragData) return;
        
        moveCounter++;
        
        const deltaX = clientX - dragData.startX;
        const deltaY = clientY - dragData.startY;
        
        let newLeft = dragData.initialLeft + deltaX;
        let newTop = dragData.initialTop + deltaY;
        
        const targetWindow = window.top || window;
        const maxX = $(targetWindow).width() - 100;
        const maxY = $(targetWindow).height() - 100;
        
        newLeft = Math.max(0, Math.min(newLeft, maxX));
        newTop = Math.max(0, Math.min(newTop, maxY));
        
        const currentContainer = window.top ? window.top.document.getElementById('character-status') : document.getElementById('character-status');
        
        if (currentContainer) {
            currentContainer.style.left = newLeft + 'px';
            currentContainer.style.top = newTop + 'px';
        }
    }
    
    const targetDocument = window.top ? window.top.document : document;
    const $targetDoc = $(targetDocument);
    
    $targetDoc.on('mousemove.drag-move', function(e) {
        handleDragMove(e.clientX, e.clientY);
        if (dragData) e.preventDefault();
    });
    
    $targetDoc.on('touchmove.drag-move', function(e) {
        const touch = e.originalEvent.touches[0];
        handleDragMove(touch.clientX, touch.clientY);
        if (dragData) e.preventDefault();
    });
    
    function handleDragEnd() {
        if (!dragData) return;
        
        const currentContainer = window.top ? window.top.document.getElementById('character-status') : document.getElementById('character-status');
        
        if (currentContainer) {
            currentContainer.classList.remove('dragging');
        }
        
        let currentLeft = 0, currentTop = 0;
        if (currentContainer) {
            const targetWindow = window.top && window.top.document === currentContainer.ownerDocument ? window.top : window;
            const computedStyle = targetWindow.getComputedStyle(currentContainer);
            currentLeft = parseInt(computedStyle.left) || 0;
            currentTop = parseInt(computedStyle.top) || 0;
        }
        const position = {
            left: currentLeft,
            top: currentTop
        };
        localStorage.setItem('character-status-position', JSON.stringify(position));
        
        dragData = null;
        moveCounter = 0;
    }
    
    $targetDoc.on('mouseup.drag-up', function(e) {
        handleDragEnd();
    });
    
    $targetDoc.on('touchend.drag-up touchcancel.drag-up', function(e) {
        handleDragEnd();
    });
    
    dragHandlersAttached = true;
}

function cleanupDragFeature() {
    dragData = null;
    dragHandlersAttached = false;
    
    const container = window.top ? window.top.document.getElementById('character-status') : document.getElementById('character-status');
    if (container) {
        $(container).off('.drag');
        container.classList.remove('dragging');
        delete container.dataset.dragInitialized;
    }
    
    $(document).off('.drag');
    $(document).off('.drag-move');
    $(document).off('.drag-up');
    
    if (window.top && window.top.document !== document) {
        const $topDoc = $(window.top.document);
        $topDoc.off('mousemove.drag-move');
        $topDoc.off('mouseup.drag-up');
        $topDoc.off('touchmove.drag-move');
        $topDoc.off('touchend.drag-up');
        $topDoc.off('touchcancel.drag-up');
    }
}

function resetDragPosition() {
    const container = window.top ? window.top.document.getElementById('character-status') : document.getElementById('character-status');
    if (container) {
        container.style.left = '0';
        container.style.top = 'var(--topBarBlockSize, 60px)';
