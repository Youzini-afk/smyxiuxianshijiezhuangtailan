// ========== 样式切换功能 ==========
let currentCardStyle = 1;

// 从 localStorage 加载保存的样式
function loadSavedCardStyle() {
    try {
        const saved = localStorage.getItem('character-card-style');
        if (saved) {
            const styleNum = parseInt(saved);
            if (styleNum === 1 || styleNum === 2) {
                currentCardStyle = styleNum;
                console.log(`✅ 加载保存的样式: style${currentCardStyle}`);
                return currentCardStyle;
            }
        }
    } catch (e) {
        console.warn('⚠️ 加载样式设置失败');
    }
    return 1; // 默认样式1
}

function toggleCardStyle() {
    currentCardStyle = currentCardStyle === 1 ? 2 : 1;
    const $container = window.top ? $(window.top.document).find('#character-status') : $('#character-status');
    $container.attr('data-style', `style${currentCardStyle}`);
    
    // 保存样式选择到 localStorage
    try {
        localStorage.setItem('character-card-style', currentCardStyle.toString());
        console.log(`✨ 切换到样式${currentCardStyle} (已保存)`);
    } catch (e) {
        console.warn('⚠️ 保存样式设置失败');
        console.log(`✨ 切换到样式${currentCardStyle}`);
    }
}

// ========== 初始化卡片样式 ==========
function initializeCardStyles() {
    const $container = window.top ? $(window.top.document).find('#character-status') : $('#character-status');
    
    // 加载保存的样式,如果没有则使用默认 style1
    const savedStyle = loadSavedCardStyle();
    $container.attr('data-style', `style${savedStyle}`);
    console.log(`✅ 卡片样式初始化为 style${savedStyle}`);
}

// ========== 设置事件委托 ==========
function setupEventDelegation() {
    const $container = window.top ? $(window.top.document).find('#character-status') : $('#character-status');
    
    $container.off('click');
    
    $container.on('click', '[data-action]', async function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        const $btn = $(this);
        const action = $btn.data('action');
        
        console.log('🔔 按钮被点击:', action);
        
        if ($btn.prop('disabled')) {
            console.warn('⚠️ 按钮已禁用，忽略点击');
            return;
        }
    
        try {
            switch(action) {
                case 'toggle-style':
                    console.log('🎨 切换样式...');
                    toggleCardStyle();
                    break;
                    
                case 'refresh':
                    console.log('🔄 开始刷新数据...');
                    $btn.addClass('refreshing').prop('disabled', true);
        
                    try {
                        console.log('🔧 触发重新处理变量...');
                        await reprocessCurrentMessageVariables();
            
                        console.log('⏳ 等待变量处理完成...');
                        await new Promise(resolve => setTimeout(resolve, 500));
            
                        console.log('🔄 刷新显示数据...');
                        loadAndDisplay();
            
                        console.log('✅ 刷新完成');
                    } finally {
                        setTimeout(() => {
                            $btn.removeClass('refreshing').prop('disabled', false);
                        }, 500);
                    }
                    break;
                    
                case 'flip-card':
                    const cardId = $btn.data('card-id');
                    if (cardId) {
                        console.log('🔄 翻转卡片:', cardId);
                        flipCharacterCard(cardId);
                        // 立即保存状态变化
                        setTimeout(() => saveCardStates(), 50);
                    } else {
                        console.error('❌ 未找到卡片ID');
                    }
                    break;
                
                case 'toggle-collapse':
                    const collapseCardId = $btn.data('card-id');
                    if (collapseCardId) {
                        console.log('📌 切换收起状态:', collapseCardId);
                        const $cardWrapper = $(`#${collapseCardId}`);
                        $cardWrapper.toggleClass('collapsed');
                        
                        const isCollapsed = $cardWrapper.hasClass('collapsed');
                        $btn.html(isCollapsed ? ICONS.pinFilled : ICONS.pin);
                        $btn.attr('title', isCollapsed ? '展开' : '收起');
                        
                        // 立即保存状态变化
                        saveCardStates();
                    } else {
                        console.error('❌ 未找到卡片ID');
                    }
                    break;
                
                case 'force-desire':
                    console.log('🔥 执行强制发情指令...');
                    $btn.prop('disabled', true);
                    try {
                        await sendForceInstruction('desire');
                    } finally {
                        setTimeout(() => {
                            $btn.prop('disabled', false);
                        }, 2000);
                    }
                    break;
                
                case 'force-crush':
                    console.log('💕 执行强制暗恋指令...');
                    $btn.prop('disabled', true);
                    try {
                        await sendForceInstruction('crush');
                    } finally {
                        setTimeout(() => {
                            $btn.prop('disabled', false);
                        }, 2000);
                    }
                    break;
                    
                default:
                    console.warn('⚠️ 未知的操作:', action);
            }
        } catch (error) {
            console.error('❌ 操作失败:', error);
            if (typeof toastr !== 'undefined') {
                toastr.error('操作失败：' + error.message);
            }
        }
    });
    
    console.log('✅ 事件委托已设置');
}

// ========== 世界书数据同步功能 ==========
async function syncDataToWorldbook(characters, bondsData) {
    try {
        console.log('📚 开始同步数据到世界书...');
        
        // 检查世界书API是否可用
        if (typeof getCharWorldbookNames !== 'function') {
            console.warn('⚠️ getCharWorldbookNames 函数不可用，跳过世界书同步');
            return;
        }
        
        // 获取当前角色绑定的世界书
        const worldbooks = getCharWorldbookNames('current');
        console.log('📖 角色绑定的世界书:', worldbooks);
        
        if (!worldbooks.primary && worldbooks.additional.length === 0) {
            console.log('📝 当前角色未绑定世界书，跳过同步');
            return;
        }
        
        // 为每个角色同步数据
        for (const charKey of characters) {
            const beauty = bondsData[charKey];
            const name = beauty.基础信息?.姓名?.[0] || charKey;
            const entryName = `${name}当前档案`;
            
            // 构建YAML格式的数据
            const yamlData = buildCharacterYAML(charKey, beauty);
            
            console.log(`📋 为 ${charKey} 构建的YAML数据:`, yamlData);
            
            // 构建世界书条目配置
            const entryConfig = {
                name: entryName,
                enabled: true,
                strategy: {
                    type: 'selective', // 绿灯
                    keys: [name], // 关键词是角色真实姓名（如"云蕴"）
                    keys_secondary: { logic: 'and_any', keys: [] },
                    scan_depth: 'same_as_global'
                },
                position: {
                    type: 'before_character_definition', // 角色定义之前
                    order: 100
                },
                content: yamlData,
                probability: 100,
                recursion: {
                    prevent_incoming: true, // 不可递归
                    prevent_outgoing: true, // 防止进一步递归
                    delay_until: null
                },
                effect: {
                    sticky: null,
                    cooldown: null,
                    delay: null
                }
            };
            
            console.log(`🔄 开始同步条目: ${entryName}`);
            console.log(`🔑 关键词设置: [${name}] (角色真实姓名)`);
            console.log('⚙️ 条目配置:', entryConfig);
            
            // 实际创建世界书条目
            await createOrUpdateWorldbookEntry(worldbooks, entryName, entryConfig);
        }
        
        // 创建或更新"所有角色档案"
        await createOrUpdateAllCharactersEntry(worldbooks, characters, bondsData);
        
    } catch (error) {
        console.error('❌ 同步数据到世界书失败:', error);
    }
}

function buildCharacterYAML(charKey, beauty) {
    const name = beauty.基础信息?.姓名?.[0] || charKey;
    const age = beauty.基础信息?.年龄?.[0] || '-';
    const identity = beauty.基础信息?.身份?.[0] || '-';
    const heartbeat = beauty.心跳?.[0] || 80;
    const thought = beauty.心理状态?.当前所想?.[0] || '';
    
    // 调试信息
    console.log(`🔍 构建YAML - charKey: ${charKey}, name: ${name}`);
    console.log(`🔍 基础信息:`, beauty.基础信息);
    
    const appearance = beauty.基础信息?.外貌 || {};
    const clothing = beauty.服装 || {};
    const bodyFeatures = beauty.身体特征 || {};
    const sexExp = beauty.性经验 || {};
    const physState = beauty.生理状态 || {};
    
    let yaml = `# ${name}当前档案\n`;
    yaml += `姓名: ${name}\n`;
    yaml += `年龄: ${age}\n`;
    yaml += `身份: ${identity}\n`;
    yaml += `心跳: ${heartbeat}\n`;
    
    if (thought) {
        yaml += `当前所想: "${thought}"\n`;
    }
    
    // 外貌信息
    if (Object.keys(appearance).length > 0) {
        yaml += `外貌:\n`;
        if (appearance.身高?.[0]) yaml += `  身高: ${appearance.身高[0]}\n`;
        if (appearance.发色?.[0]) yaml += `  发色: ${appearance.发色[0]}\n`;
        if (appearance.发型?.[0]) yaml += `  发型: ${appearance.发型[0]}\n`;
        if (appearance.瞳色?.[0]) yaml += `  瞳色: ${appearance.瞳色[0]}\n`;
        if (appearance.肤色?.[0]) yaml += `  肤色: ${appearance.肤色[0]}\n`;
        if (appearance.体型?.[0]) yaml += `  体型: ${appearance.体型[0]}\n`;
    }
    
    // 服装信息
    if (Object.keys(clothing).length > 0) {
        yaml += `服装:\n`;
        if (clothing.上衣?.[0]) yaml += `  上衣: ${clothing.上衣[0]}\n`;
        if (clothing.下装?.[0]) yaml += `  下装: ${clothing.下装[0]}\n`;
        if (clothing.内衣?.[0]) yaml += `  内衣: ${clothing.内衣[0]}\n`;
        if (clothing.内裤?.[0]) yaml += `  内裤: ${clothing.内裤[0]}\n`;
        if (clothing.丝袜?.[0]) yaml += `  丝袜: ${clothing.丝袜[0]}\n`;
        if (clothing.鞋子?.[0]) yaml += `  鞋子: ${clothing.鞋子[0]}\n`;
    }
    
    // 身体特征
    if (Object.keys(bodyFeatures).length > 0) {
        yaml += `身体特征:\n`;
        const measurements = bodyFeatures.三围 || {};
        if (Object.keys(measurements).length > 0) {
            yaml += `  三围:\n`;
            if (measurements.胸围?.[0]) yaml += `    胸围: ${measurements.胸围[0]}\n`;
            if (measurements.腰围?.[0]) yaml += `    腰围: ${measurements.腰围[0]}\n`;
            if (measurements.臀围?.[0]) yaml += `    臀围: ${measurements.臀围[0]}\n`;
            if (measurements.罩杯?.[0]) yaml += `    罩杯: ${measurements.罩杯[0]}\n`;
        }
        
        const breast = bodyFeatures.乳房 || {};
        if (Object.keys(breast).length > 0) {
            yaml += `  乳房:\n`;
            if (breast.形状?.[0]) yaml += `    形状: ${breast.形状[0]}\n`;
            if (breast.乳头颜色?.[0]) yaml += `    乳头颜色: ${breast.乳头颜色[0]}\n`;
        }
        
        if (bodyFeatures.私处?.类型?.[0]) {
            yaml += `  私处类型: ${bodyFeatures.私处.类型[0]}\n`;
        }
    }
    
    // 性经验
    if (Object.keys(sexExp).length > 0) {
        yaml += `性经验:\n`;
        if (sexExp.处女?.[0]) yaml += `  处女: ${sexExp.处女[0]}\n`;
        if (sexExp.性行为次数?.[0]) yaml += `  性行为次数: ${sexExp.性行为次数[0]}\n`;
        if (sexExp.性伴侣数量?.[0]) yaml += `  性伴侣数量: ${sexExp.性伴侣数量[0]}\n`;
        if (sexExp.肛交经验?.[0]) yaml += `  肛交经验: ${sexExp.肛交经验[0]}\n`;
        if (sexExp.口交经验?.[0]) yaml += `  口交经验: ${sexExp.口交经验[0]}\n`;
        if (sexExp.初次性行为对象?.[0]) yaml += `  初次性行为对象: ${sexExp.初次性行为对象[0]}\n`;
    }
    
    // 生理状态
    if (Object.keys(physState).length > 0) {
        yaml += `生理状态:\n`;
        if (physState.体液分泌?.[0]) yaml += `  体液分泌: ${physState.体液分泌[0]}\n`;
        if (physState.乳头状态?.[0]) yaml += `  乳头状态: ${physState.乳头状态[0]}\n`;
        if (physState.阴蒂状态?.[0]) yaml += `  阴蒂状态: ${physState.阴蒂状态[0]}\n`;
        if (physState.子宫状态?.[0]) yaml += `  子宫状态: ${physState.子宫状态[0]}\n`;
        if (physState.月经周期?.[0]) yaml += `  月经周期: ${physState.月经周期[0]}\n`;
        if (physState.怀孕状态?.[0]) yaml += `  怀孕状态: ${physState.怀孕状态[0]}\n`;
    }
    
    // 敏感部位
    if (beauty.敏感部位) {
        const parts = Object.keys(beauty.敏感部位).filter(k => k !== '$meta');
        if (parts.length > 0) {
            yaml += `敏感部位:\n`;
            parts.forEach(part => {
                const reaction = beauty.敏感部位[part]?.反应描述?.[0] || '-';
                yaml += `  ${part}: "${reaction}"\n`;
            });
        }
    }
    
    
    return yaml;
}

// ========== 所有角色档案功能（累积记录） ==========
async function createOrUpdateAllCharactersEntry(worldbooks, characters, bondsData) {
    try {
        const entryName = "所有角色档案";
        console.log('📚 开始处理"所有角色档案"（累积模式）...');
        
        // 确定要操作的世界书名称
        const targetWorldbook = worldbooks.primary || worldbooks.additional[0];
        if (!targetWorldbook) {
            console.error('❌ 没有找到可用的世界书');
            return;
        }
        
        // 尝试读取现有的"所有角色档案"内容
        let existingCharacters = new Set();
        let existingContent = '';
        
        console.log('🔍 尝试读取现有的"所有角色档案"...');
        
        // 尝试多种方式读取现有条目
        let existingEntry = null;
        
        if (typeof getWorldbookEntries === 'function') {
