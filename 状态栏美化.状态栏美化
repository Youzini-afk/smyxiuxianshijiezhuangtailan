        } else {
            console.error('❌ 创建世界书条目失败');
        }

    } catch (error) {
        console.error('❌ 创建/更新世界书条目时出错:', error);
        if (typeof toastr !== 'undefined') {
            toastr.error(`同步世界书失败: ${error.message}`);
        }
    }
}

