        let newContent = existingContent;
        
        for (const charKey of characters) {
            const beauty = bondsData[charKey];
            const name = beauty.基础信息?.姓名?.[0] || charKey;
            
            if (!existingCharacters.has(name)) {
                // 推测性别
                let gender = '女'; // 默认女性
                if (beauty.基础信息?.性别?.[0]) {
                    gender = beauty.基础信息.性别[0];
                }
                
                console.log(`➕ 添加新角色到档案: ${name} (${gender})`);
                newContent += `角色名: ${name}\n`;
                newContent += `性别: ${gender}\n\n`;
                existingCharacters.add(name);
                hasNewCharacters = true;
            } else {
                console.log(`ℹ️ 角色已存在，跳过: ${name}`);
            }
        }
        
        // 只有在有新角色时才更新
        if (hasNewCharacters || !existingEntry) {
            const entryConfig = {
                name: entryName,
                enabled: true,
                strategy: {
                    type: 'constant', // 蓝灯
                    keys: [],
                    keys_secondary: { logic: 'and_any', keys: [] },
                    scan_depth: 'same_as_global'
                },
                position: {
                    type: 'before_character_definition',
                    order: 100
                },
                content: newContent,
                probability: 100,
                recursion: {
                    prevent_incoming: true, // 不可递归
                    prevent_outgoing: true, // 防止进一步递归
                    delay_until: null
                },
                effect: {
                    sticky: null,
                    cooldown: null,
                    delay: null
                }
            };
            
            console.log('📋 更新后的"所有角色档案"数据:', newContent);
            
            // 使用标准的创建/更新函数
            await createOrUpdateWorldbookEntry(worldbooks, entryName, entryConfig);
            
            if (hasNewCharacters) {
                console.log(`✅ "所有角色档案"已更新，新增了角色`);
            } else {
                console.log(`✅ "所有角色档案"已创建`);
            }
        } else {
            console.log('ℹ️ "所有角色档案"无需更新，没有新角色');
        }

    } catch (error) {
        console.error('❌ 处理"所有角色档案"时出错:', error);
    }
}

// ========== 检测世界书条目是否存在 ==========
async function checkWorldbookEntryExists(worldbooks, entryName) {
    try {
        // 确定要操作的世界书名称
        const targetWorldbook = worldbooks.primary || worldbooks.additional[0];
        if (!targetWorldbook) {
            return false;
        }

        console.log(`🔍 检测条目是否存在: ${entryName}`);

        // 尝试创建一个测试条目来检测是否已存在
        // 如果条目已存在，创建会失败或返回特定错误
        try {
            const testConfig = {
                name: entryName + '_test_' + Date.now(), // 使用测试名称
                enabled: false,
                strategy: { type: 'constant', keys: [] },
                content: 'test',
                probability: 0
            };

            // 先尝试创建测试条目
            const testResult = await createWorldbookEntries(
                targetWorldbook,
                [testConfig],
                { render: 'none' }
            );

            // 如果测试条目创建成功，立即删除它
            if (testResult.new_entries.length > 0) {
                try {
                    await deleteWorldbookEntries(
                        targetWorldbook,
                        entry => entry.name === testConfig.name,
                        { render: 'none' }
                    );
                } catch (e) {
                    console.warn('⚠️ 删除测试条目失败:', e.message);
                }
            }

            // 现在尝试删除目标条目来检测是否存在
            const deleteResult = await deleteWorldbookEntries(
                targetWorldbook,
                entry => entry.name === entryName,
                { render: 'none' }
            );

            if (deleteResult.deleted_entries && deleteResult.deleted_entries.length > 0) {
                console.log(`✅ 检测到条目存在: ${entryName}`);
                
                const originalEntry = deleteResult.deleted_entries[0];
                
                // 立即重新创建被删除的条目（恢复）
                const restoreConfig = {
                    name: entryName,
                    enabled: true,
                    strategy: { type: 'constant', keys: [] },
                    content: originalEntry.content || '',
                    probability: 100,
                    position: { type: 'before_character_definition', order: 100 },
                    recursion: { prevent_incoming: true, prevent_outgoing: true }
                };

                await createWorldbookEntries(
                    targetWorldbook,
                    [restoreConfig],
                    { render: 'none' }
                );
                
                console.log(`🔄 已恢复条目: ${entryName}`);
                
                // 将原始条目内容存储到全局变量，供后续使用
                window._tempEntryContent = originalEntry.content || '';
                
                return true;
            } else {
                console.log(`❌ 条目不存在: ${entryName}`);
                return false;
            }

        } catch (error) {
            console.warn('⚠️ 检测条目存在性时出错:', error.message);
            return false;
        }

    } catch (error) {
        console.error('❌ 检测世界书条目存在性失败:', error);
        return false;
    }
}

