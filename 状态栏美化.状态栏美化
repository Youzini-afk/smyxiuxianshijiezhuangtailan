function diagnoseMvuAvailability() {
    console.log('🔍 MVU框架诊断:');
    console.log('  - typeof Mvu:', typeof Mvu);
    console.log('  - typeof window.Mvu:', typeof window.Mvu);
    
    if (window.self !== window.top && window.parent) {
        try {
            console.log('  - 父窗口 typeof Mvu:', typeof window.parent.Mvu);
        } catch (e) {
            console.log('  - 无法访问父窗口Mvu:', e.message);
        }
    }
}

function waitForMvu(callback, maxAttempts = 20) {
    let attempts = 0;
    
    const checkMvu = () => {
        attempts++;
        
        const mvuExists = typeof Mvu !== 'undefined' ||
                         typeof window.Mvu !== 'undefined' ||
                         (window.parent && typeof window.parent.Mvu !== 'undefined');
        
        if (mvuExists) {
            console.log('✅ MVU框架已检测到');
            
            if (typeof Mvu === 'undefined' && window.parent && typeof window.parent.Mvu !== 'undefined') {
                window.Mvu = window.parent.Mvu;
                console.log('✅ 已从父窗口引用MVU');
            }
            
            callback();
        } else if (attempts < maxAttempts) {
            if (attempts === 1 || attempts % 5 === 0) {
                console.log(`⏳ 等待MVU框架... (${attempts}/${maxAttempts})`);
            }
            setTimeout(checkMvu, 1000);
        } else {
            console.warn('⚠️ MVU框架预检测超时，继续初始化');
            diagnoseMvuAvailability();
            callback();
        }
    };
    
    checkMvu();
}

